{
  "expo": {
    "name": "QuoteWise",
    "slug": "quotewise",
    "version": "4.7.0",
    "extra": {
      "eas": {
        "projectId": "e2d31ea2-9677-4f84-95c6-bf4aa6275491"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "assets/images/**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F05A00"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quotewise.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F05A00",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.quotewise.app",
      "softwareMenuBar": false,
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "quotewises-organization",
    "plugins": [
      "expo-sharing",
      "./plugins/withApkName.js"
    ]
  }
}
